<launch>
    
    <!-- 1. [核心修复] 发布静态 TF 变换 -->
    <!-- args: x y z yaw pitch roll parent_frame child_frame period_ms -->
    <node pkg="tf" type="static_transform_publisher" name="lidar_to_body" args="0 0 0 0 0 0 base_link laser_livox 100" />
    
    <!-- 2. 启动规划节点 (大脑) -->
    <node pkg="ego_planner" type="ego_planner_node" name="ego_planner_node" output="screen">
        <rosparam command="load" file="$(find ego_planner)/config/ego_planner.yaml" />
    </node>

    <!-- 3. 启动 RViz 可视化 -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find ego_planner)/config/ego_planner.rviz" />

</launch>
